<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE properties SYSTEM 'http://java.sun.com/dtd/properties.dtd'>
<properties>

    <!-- Base de Datos -->
    <entry key='database.driver'>org.postgresql.Driver</entry>
    <entry key='database.url'>jdbc:postgresql://traccar-postgres:5432/traccar</entry>
    <entry key='database.user'>traccar</entry>
    <entry key='database.password'>traccar</entry>

    <!-- Protocolo JT808 -->
    <entry key='jt808.port'>21081</entry>
    <entry key='jt808.udp.port'>21081</entry>
    <entry key='jt808.timezone'>America/Bogota</entry>

    <!-- JT1078 video histórico por celular (SIM/NAT)
         IP a la que el MDVR conecta para enviar el video (puerto 8400).
         En local: IP del servidor en la red local.
         En producción: reemplazar por la IP pública del servidor en la nube. -->
    <entry key='jt1078.serverHost'>192.168.1.8</entry>

    <!-- Interfaz Web y Logs (Cambiado a 'info' por seguridad) -->
    <entry key='web.port'>8082</entry>
    <entry key='web.url'>https://m2ffzvn2-8082.use.devtunnels.ms</entry>
    <entry key='logger.level'>info</entry>

    <!-- Copiado de Atributos (Se eliminó la línea .enable que no es válida) -->
    <entry key='processing.copyAttributes'>passengersOn,passengersOff,passengersOnFront,passengersOffFront,passengersOnRear,passengersOffRear</entry>

    <!-- Tiempo máximo sin actividad antes de marcar dispositivo como desconocido (segundos) -->
    <entry key='deviceTimeout'>3600</entry>

    <!-- SMTP para reset de contraseña — configurar en la VM directamente en traccar.xml
    <entry key='mail.smtp.host'>smtp.gmail.com</entry>
    <entry key='mail.smtp.port'>587</entry>
    <entry key='mail.smtp.starttls.enable'>true</entry>
    <entry key='mail.smtp.auth'>true</entry>
    <entry key='mail.smtp.username'>CORREO@gmail.com</entry>
    <entry key='mail.smtp.password'>CONTRASENA_APP_16_CHARS</entry>
    <entry key='mail.smtp.from'>CORREO@gmail.com</entry>
    -->

</properties>
